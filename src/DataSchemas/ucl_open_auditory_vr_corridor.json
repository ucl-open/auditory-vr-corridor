{
  "$defs": {
    "BehaviorBoard": {
      "description": "Represents a Harp Behavior Board device.",
      "properties": {
        "deviceType": {
          "const": "BehaviorBoard",
          "default": "BehaviorBoard",
          "title": "DeviceType",
          "type": "string"
        },
        "portName": {
          "description": "The name of the device serial port.",
          "examples": [
            "COM"
          ],
          "title": "PortName",
          "type": "string"
        },
        "pulseController": {
          "default": null,
          "description": "Optional PulseController module for generating digital output pulses.",
          "oneOf": [
            {
              "$ref": "#/$defs/PulseController"
            },
            {
              "type": "null"
            }
          ],
          "title": "PulseController"
        },
        "cameraController": {
          "default": null,
          "description": "Optional CameraController module for emitting camera trigger pulses.",
          "oneOf": [
            {
              "$ref": "#/$defs/CameraController"
            },
            {
              "type": "null"
            }
          ],
          "title": "CameraController"
        },
        "runningWheel": {
          "default": null,
          "description": "Optional RunningWheelModule module to define wheel geometry.",
          "oneOf": [
            {
              "$ref": "#/$defs/RunningWheelModule"
            },
            {
              "type": "null"
            }
          ],
          "title": "RunningWheel"
        }
      },
      "required": [
        "portName"
      ],
      "title": "BehaviorBoard",
      "type": "object"
    },
    "CameraController": {
      "description": "Represents a CameraController Module for a BehaviourBoard device.\nMirrors the externalized properties of the Bonsai workflow of the same name,\nexcluding subject name properties.",
      "properties": {
        "triggerFrequency": {
          "description": "The frequency, in Hz, at which to emit camera triggers from DO0 of a behavior board (`CameraOutput0`)",
          "examples": [
            "50"
          ],
          "title": "TriggerFrequency",
          "type": "integer"
        }
      },
      "required": [
        "triggerFrequency"
      ],
      "title": "CameraController",
      "type": "object"
    },
    "LogConfig": {
      "description": "Logging params.",
      "properties": {
        "loggingRootPath": {
          "default": ".\\logs",
          "description": "Root path for logs",
          "title": "LoggingRootPath",
          "type": "string"
        },
        "sessionId": {
          "description": "Unique session identifier, defaults to timestamp",
          "title": "SessionId",
          "type": "string"
        },
        "animalId": {
          "default": "unknown_animal",
          "description": "Animal identifier for the session",
          "title": "AnimalId",
          "type": "string"
        }
      },
      "title": "LogConfig",
      "type": "object"
    },
    "PulseController": {
      "description": "Represents the PulseController module on the BehaviourBoard.\nMirrors the externalized properties of the Bonsai workflow of the same name,\nexcluding subject name properties.",
      "properties": {
        "outputPulseEnable": {
          "description": "List of digital output lines that are enabled for pulse generation.",
          "items": {
            "type": "string"
          },
          "title": "OutputPulseEnable",
          "type": "array"
        },
        "pulseWidths": {
          "$ref": "#/$defs/PulseWidths",
          "description": "Pulse width configuration for DO1, DO2, and DO3 lines."
        }
      },
      "required": [
        "pulseWidths"
      ],
      "title": "PulseController",
      "type": "object"
    },
    "PulseWidths": {
      "properties": {
        "PulseDO1": {
          "maximum": 65535,
          "minimum": 0,
          "title": "PulseDo1",
          "type": "integer"
        },
        "PulseDO2": {
          "maximum": 65535,
          "minimum": 0,
          "title": "PulseDo2",
          "type": "integer"
        },
        "PulseDO3": {
          "maximum": 65535,
          "minimum": 0,
          "title": "PulseDo3",
          "type": "integer"
        }
      },
      "required": [
        "PulseDO1",
        "PulseDO2",
        "PulseDO3"
      ],
      "title": "PulseWidths",
      "type": "object"
    },
    "PunishmentConfig": {
      "description": "Punishment params.",
      "properties": {
        "timeoutSec": {
          "default": 5,
          "description": "Timeout duration in seconds",
          "title": "TimeoutSec",
          "type": "integer"
        },
        "stage4PunishedLick": {
          "default": 5,
          "description": "Punished lick in stage 4",
          "minimum": 1,
          "title": "Stage4PunishedLick",
          "type": "integer"
        },
        "stage5PunishedLick": {
          "default": 4,
          "description": "Punished lick in stage 5",
          "minimum": 1,
          "title": "Stage5PunishedLick",
          "type": "integer"
        },
        "stage6PunishedLick": {
          "default": 3,
          "description": "Punished lick in stage 6",
          "minimum": 1,
          "title": "Stage6PunishedLick",
          "type": "integer"
        }
      },
      "title": "PunishmentConfig",
      "type": "object"
    },
    "RunningWheelModule": {
      "description": "Represents the RunningWheel Bonsai workflow module.\nExposes wheel geometry parameters used to compute speed and distance from encoder counts.",
      "properties": {
        "countsPerRev": {
          "description": "Number of encoder counts per full revolution of the running wheel.",
          "title": "CountsPerRev",
          "type": "integer"
        },
        "wheelDiameterMm": {
          "description": "The diameter, in millimeters, of the running wheel.",
          "title": "WheelDiameterMm",
          "type": "number"
        }
      },
      "required": [
        "countsPerRev",
        "wheelDiameterMm"
      ],
      "title": "RunningWheelModule",
      "type": "object"
    },
    "Stage": {
      "description": "Frequency boundaries for a single shaping stage.",
      "properties": {
        "floor": {
          "description": "Lower frequency threshold (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "Floor",
          "type": "integer"
        },
        "ceiling": {
          "description": "Upper frequency ceiling (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "Ceiling",
          "type": "integer"
        }
      },
      "required": [
        "floor",
        "ceiling"
      ],
      "title": "Stage",
      "type": "object"
    },
    "ThresholdFrequencies": {
      "description": "Floor and ceiling frequencies of the reward zone for each shaping stage.",
      "properties": {
        "stage1": {
          "$ref": "#/$defs/Stage",
          "title": "Stage1"
        },
        "stage2": {
          "$ref": "#/$defs/Stage",
          "title": "Stage2"
        },
        "stage3": {
          "$ref": "#/$defs/Stage",
          "title": "Stage3"
        },
        "stage4": {
          "$ref": "#/$defs/Stage",
          "title": "Stage4"
        },
        "stage5": {
          "$ref": "#/$defs/Stage",
          "title": "Stage5"
        },
        "stage6": {
          "$ref": "#/$defs/Stage",
          "title": "Stage6"
        }
      },
      "required": [
        "stage1",
        "stage2",
        "stage3",
        "stage4",
        "stage5",
        "stage6"
      ],
      "title": "ThresholdFrequencies",
      "type": "object"
    },
    "UclOpenAuditoryVrCorridorRig": {
      "properties": {
        "version": {
          "const": "0.0.0-rc1",
          "default": "0.0.0-rc1",
          "title": "Version",
          "type": "string"
        },
        "behaviorboard": {
          "$ref": "#/$defs/BehaviorBoard",
          "title": "Behaviorboard"
        },
        "runningwheel": {
          "$ref": "#/$defs/RunningWheelModule",
          "title": "Runningwheel"
        }
      },
      "required": [
        "behaviorboard",
        "runningwheel"
      ],
      "title": "UclOpenAuditoryVrCorridorRig",
      "type": "object"
    },
    "UclOpenAuditoryVrCorridorTaskLogic": {
      "description": "Top-level task logic schema.",
      "properties": {
        "version": {
          "const": "0.0.0-rc1",
          "default": "0.0.0-rc1",
          "title": "Version",
          "type": "string"
        },
        "name": {
          "const": "UclOpenAuditoryVrCorridor",
          "default": "UclOpenAuditoryVrCorridor",
          "description": "Name of the task",
          "title": "Name",
          "type": "string"
        },
        "taskParameters": {
          "$ref": "#/$defs/UclOpenAuditoryVrCorridorTaskParameters",
          "default": {
            "shapingStage": 1,
            "startFreq": 2000,
            "endFreq": 25000,
            "nFreqBins": 100,
            "centerFreq": 18000,
            "stage5WindowSize": 8000,
            "stage6WindowSize": 4000,
            "thresholdFrequencies": {
              "stage1": {
                "ceiling": 25000,
                "floor": 18000
              },
              "stage2": {
                "ceiling": 25000,
                "floor": 18000
              },
              "stage3": {
                "ceiling": 25000,
                "floor": 12960
              },
              "stage4": {
                "ceiling": 25000,
                "floor": 12960
              },
              "stage5": {
                "ceiling": 22439,
                "floor": 14439
              },
              "stage6": {
                "ceiling": 20110,
                "floor": 16110
              }
            },
            "punishment": {
              "stage4PunishedLick": 5,
              "stage5PunishedLick": 4,
              "stage6PunishedLick": 3,
              "timeoutSec": 5
            },
            "logConfig": {
              "animalId": "unknown_animal",
              "loggingRootPath": ".\\logs",
              "sessionId": "2026-05-06T16_53_26"
            },
            "amplitude": 0.5,
            "quantizeBinSize": 1
          },
          "title": "TaskParameters"
        }
      },
      "title": "UclOpenAuditoryVrCorridorTaskLogic",
      "type": "object"
    },
    "UclOpenAuditoryVrCorridorTaskParameters": {
      "description": "Task params.",
      "properties": {
        "shapingStage": {
          "default": 1,
          "description": "Shaping stage (1-6)",
          "maximum": 6,
          "minimum": 1,
          "title": "ShapingStage",
          "type": "integer"
        },
        "startFreq": {
          "default": 2000,
          "description": "Start frequency of the sweep (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "StartFreq",
          "type": "integer"
        },
        "endFreq": {
          "default": 25000,
          "description": "End frequency of the sweep (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "EndFreq",
          "type": "integer"
        },
        "nFreqBins": {
          "default": 100,
          "description": "Number of frequency bins for quantization",
          "minimum": 10,
          "title": "NFreqBins",
          "type": "integer"
        },
        "centerFreq": {
          "default": 18000,
          "description": "Center frequency of all reward windows (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "CenterFreq",
          "type": "integer"
        },
        "stage5WindowSize": {
          "default": 8000,
          "description": "Window size around center_freq for stage 5 (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "Stage5WindowSize",
          "type": "integer"
        },
        "stage6WindowSize": {
          "default": 4000,
          "description": "Window size around center_freq for stage 6 (Hz)",
          "maximum": 25000,
          "minimum": 1,
          "title": "Stage6WindowSize",
          "type": "integer"
        },
        "thresholdFrequencies": {
          "default": null,
          "oneOf": [
            {
              "$ref": "#/$defs/ThresholdFrequencies"
            },
            {
              "type": "null"
            }
          ],
          "title": "ThresholdFrequencies"
        },
        "punishment": {
          "$ref": "#/$defs/PunishmentConfig",
          "default": {
            "timeoutSec": 5,
            "stage4PunishedLick": 5,
            "stage5PunishedLick": 4,
            "stage6PunishedLick": 3
          },
          "title": "Punishment"
        },
        "logConfig": {
          "$ref": "#/$defs/LogConfig",
          "default": {
            "loggingRootPath": ".\\logs",
            "sessionId": "2026-05-06T16_53_26",
            "animalId": "unknown_animal"
          }
        },
        "amplitude": {
          "default": 0.5,
          "description": "Audio amplitude (0.0 to 1.0)",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Amplitude",
          "type": "number"
        },
        "quantizeBinSize": {
          "default": 1,
          "description": "Bin size for frequency quantization (Hz)",
          "minimum": 1,
          "title": "QuantizeBinSize",
          "type": "integer"
        }
      },
      "title": "UclOpenAuditoryVrCorridorTaskParameters",
      "type": "object"
    }
  }
}