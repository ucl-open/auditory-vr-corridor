<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:harp="clr-namespace:Bonsai.Harp;assembly=Bonsai.Harp"
                 xmlns:p1="clr-namespace:Harp.TimestampGeneratorGen3;assembly=Harp.TimestampGeneratorGen3"
                 xmlns:rx="clr-namespace:Bonsai.Reactive;assembly=Bonsai.Core"
                 xmlns:beh="clr-namespace:Harp.Behavior;assembly=Harp.Behavior"
                 xmlns:dsp="clr-namespace:Bonsai.Dsp;assembly=Bonsai.Dsp"
                 xmlns:scr="clr-namespace:Bonsai.Scripting.Expressions;assembly=Bonsai.Scripting.Expressions"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:p2="clr-namespace:Harp.StepperDriver;assembly=Harp.StepperDriver"
                 xmlns:p3="clr-namespace:;assembly=Extensions"
                 xmlns:aeon-video="clr-namespace:Aeon.Video;assembly=Aeon.Video"
                 xmlns:spk="clr-namespace:Bonsai.Spinnaker;assembly=Bonsai.Spinnaker"
                 xmlns:gui="clr-namespace:Bonsai.Gui;assembly=Bonsai.Gui"
                 xmlns:cv="clr-namespace:Bonsai.Vision;assembly=Bonsai.Vision"
                 xmlns:io="clr-namespace:Bonsai.IO;assembly=Bonsai.System"
                 xmlns:p4="clr-namespace:UclOpenAuditoryVrCorridorDataSchema;assembly=Extensions"
                 xmlns:gl="clr-namespace:Bonsai.Shaders;assembly=Bonsai.Shaders"
                 xmlns:res="clr-namespace:Bonsai.Resources;assembly=Bonsai.System"
                 xmlns:p5="clr-namespace:OpenCV.Net;assembly=OpenCV.Net"
                 xmlns:p6="clr-namespace:UclOpen.Core;assembly=UclOpen.Core"
                 xmlns:p7="clr-namespace:UclOpen.Logging;assembly=UclOpen.Logging"
                 xmlns:p8="clr-namespace:UclOpen.Loggingv2;assembly=Extensions"
                 xmlns:p9="clr-namespace:Bonsai.Mixer;assembly=Bonsai.Mixer"
                 xmlns:num="clr-namespace:Bonsai.Numerics;assembly=Bonsai.Numerics"
                 xmlns:wie="clr-namespace:Bonsai.Windows.Input;assembly=Bonsai.Windows.Input"
                 xmlns:p10="clr-namespace:Bonsai.Numerics.Distributions;assembly=Bonsai.Numerics"
                 xmlns:al="clr-namespace:Bonsai.Audio;assembly=Bonsai.Audio"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="GroupWorkflow">
        <Name>Devices</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="GroupWorkflow">
              <Name>TimestampGenerator</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="Unit" />
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="harp:SynchronizeTimestamp" />
                  </Expression>
                  <Expression xsi:type="p1:CreateMessage">
                    <harp:MessageType>Write</harp:MessageType>
                    <harp:Payload xsi:type="p1:CreateTimerFrequencyPayload">
                      <p1:TimerFrequency>Timer1000Hz</p1:TimerFrequency>
                    </harp:Payload>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:Merge" />
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="p1:Device">
                      <harp:OperationMode>Active</harp:OperationMode>
                      <harp:OperationLed>On</harp:OperationLed>
                      <harp:DumpRegisters>true</harp:DumpRegisters>
                      <harp:VisualIndicators>On</harp:VisualIndicators>
                      <harp:Heartbeat>Enabled</harp:Heartbeat>
                      <harp:IgnoreErrors>false</harp:IgnoreErrors>
                      <harp:PortName>COM16</harp:PortName>
                    </Combinator>
                  </Expression>
                  <Expression xsi:type="rx:PublishSubject">
                    <Name>ClockSynchronizerEvents</Name>
                  </Expression>
                  <Expression xsi:type="WorkflowOutput" />
                  <Expression xsi:type="GroupWorkflow">
                    <Name>Timestamps</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>ClockSynchronizerEvents</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="harp:FilterMessageType">
                            <harp:FilterType>Include</harp:FilterType>
                            <harp:MessageType>Event</harp:MessageType>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="harp:FilterRegister">
                          <harp:FilterType>Include</harp:FilterType>
                          <harp:Register xsi:type="harp:TimestampSeconds" />
                        </Expression>
                        <Expression xsi:type="rx:PublishSubject">
                          <Name>Heartbeats</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>ClockSynchronizerEvents</Name>
                        </Expression>
                        <Expression xsi:type="p1:Parse">
                          <harp:Register xsi:type="p1:Timer" />
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>Timestamp</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:WithLatestFrom" />
                        </Expression>
                        <Expression xsi:type="Subtract" />
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>Timebase</Name>
                        </Expression>
                        <Expression xsi:type="WorkflowOutput" />
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="1" Label="Source1" />
                        <Edge From="1" To="2" Label="Source1" />
                        <Edge From="2" To="3" Label="Source1" />
                        <Edge From="4" To="5" Label="Source1" />
                        <Edge From="5" To="6" Label="Source1" />
                        <Edge From="6" To="7" Label="Source1" />
                        <Edge From="6" To="8" Label="Source1" />
                        <Edge From="7" To="8" Label="Source2" />
                        <Edge From="8" To="9" Label="Source1" />
                        <Edge From="9" To="10" Label="Source1" />
                        <Edge From="10" To="11" Label="Source1" />
                      </Edges>
                    </Workflow>
                  </Expression>
                </Nodes>
                <Edges>
                  <Edge From="0" To="1" Label="Source1" />
                  <Edge From="1" To="3" Label="Source1" />
                  <Edge From="2" To="3" Label="Source2" />
                  <Edge From="3" To="4" Label="Source1" />
                  <Edge From="4" To="5" Label="Source1" />
                  <Edge From="5" To="6" Label="Source1" />
                </Edges>
              </Workflow>
            </Expression>
            <Expression xsi:type="GroupWorkflow">
              <Name>BehaviorBoard</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>RunningWheel</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="beh:CreateMessage">
                          <harp:MessageType>Write</harp:MessageType>
                          <harp:Payload xsi:type="beh:CreateEnableEncodersPayload">
                            <beh:EnableEncoders>EncoderPort2</beh:EnableEncoders>
                          </harp:Payload>
                        </Expression>
                        <Expression xsi:type="beh:CreateMessage">
                          <harp:MessageType>Write</harp:MessageType>
                          <harp:Payload xsi:type="beh:CreateEncoderModePayload">
                            <beh:EncoderMode>Position</beh:EncoderMode>
                          </harp:Payload>
                        </Expression>
                        <Expression xsi:type="beh:CreateMessage">
                          <harp:MessageType>Write</harp:MessageType>
                          <harp:Payload xsi:type="beh:CreateEncoderResetPayload">
                            <beh:EncoderReset>EncoderPort2</beh:EncoderReset>
                          </harp:Payload>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Merge" />
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Name" DisplayName="CommandsSubjectName" Description="The name of the Subject that carries command messages for a specific behavior device" Category="Subjects" />
                        </Expression>
                        <Expression xsi:type="MulticastSubject">
                          <Name>BehaviorCommands</Name>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Name" DisplayName="EventsSubjectName" Description="The name of the Subject that carries event messages from a specific behavior device" Category="Subjects" />
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>BehaviorEvents</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:SubscribeWhen" />
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>BehaviorEvents</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:DelaySubscription">
                            <rx:DueTime>PT0.5S</rx:DueTime>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="beh:Parse">
                          <harp:Register xsi:type="beh:AnalogData" />
                        </Expression>
                        <Expression xsi:type="MemberSelector">
                          <Selector>Encoder</Selector>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="dsp:Difference">
                            <dsp:Order>1</dsp:Order>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="scr:ExpressionTransform">
                          <scr:Name>ConvertSigned</scr:Name>
                          <scr:Expression>it &gt; 32768.0 ? it - 65536.0 : (it &lt; -32768.0 ? it + 65536.0 : it)</scr:Expression>
                        </Expression>
                        <Expression xsi:type="rx:Accumulate" />
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="CountsPerRev" />
                          <Property Name="WheelDiameterMm" />
                        </Expression>
                        <Expression xsi:type="GroupWorkflow">
                          <Name>TicksToCentimeters</Name>
                          <Description>Converts steps on a quadrature encoder to a distance in cm, published to a Subject</Description>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="ExternalizedMapping">
                                <Property Name="Value" DisplayName="CountsPerRev" Description="The number of steps recorded on the quadrature encoder in a full revolution" Category="Running Wheel" />
                              </Expression>
                              <Expression xsi:type="Divide">
                                <Operand xsi:type="WorkflowProperty" TypeArguments="sys:Int16">
                                  <Value>4096</Value>
                                </Operand>
                              </Expression>
                              <Expression xsi:type="ExternalizedMapping">
                                <Property Name="Value" DisplayName="WheelDiameterMm" Description="The diameter of the wheel, in millimetres" Category="Running Wheel" />
                              </Expression>
                              <Expression xsi:type="Combinator">
                                <Combinator xsi:type="IntProperty">
                                  <Value>75</Value>
                                </Combinator>
                              </Expression>
                              <Expression xsi:type="scr:ExpressionTransform">
                                <scr:Name>CircumferenceCm</scr:Name>
                                <scr:Expression>(it*Math.Pi)/10</scr:Expression>
                              </Expression>
                              <Expression xsi:type="PropertyMapping">
                                <PropertyMappings>
                                  <Property Name="Value" />
                                </PropertyMappings>
                              </Expression>
                              <Expression xsi:type="Multiply">
                                <Operand xsi:type="FloatProperty">
                                  <Value>23.561945</Value>
                                </Operand>
                              </Expression>
                              <Expression xsi:type="WorkflowOutput" />
                            </Nodes>
                            <Edges>
                              <Edge From="0" To="2" Label="Source2" />
                              <Edge From="1" To="2" Label="Source3" />
                              <Edge From="2" To="7" Label="Source1" />
                              <Edge From="3" To="4" Label="Source1" />
                              <Edge From="4" To="5" Label="Source1" />
                              <Edge From="5" To="6" Label="Source1" />
                              <Edge From="6" To="7" Label="Source2" />
                              <Edge From="7" To="8" Label="Source1" />
                            </Edges>
                          </Workflow>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Name" DisplayName="WheelDistanceSubjectName" Description="The name of the Subject that carries the wheel distance in cm" Category="Subjects" />
                        </Expression>
                        <Expression xsi:type="rx:PublishSubject">
                          <Name>WheelDistanceCm</Name>
                        </Expression>
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="3" Label="Source1" />
                        <Edge From="1" To="3" Label="Source2" />
                        <Edge From="2" To="3" Label="Source3" />
                        <Edge From="3" To="5" Label="Source1" />
                        <Edge From="4" To="5" Label="Source2" />
                        <Edge From="5" To="8" Label="Source1" />
                        <Edge From="6" To="7" Label="Source1" />
                        <Edge From="6" To="9" Label="Source1" />
                        <Edge From="7" To="8" Label="Source2" />
                        <Edge From="9" To="10" Label="Source1" />
                        <Edge From="10" To="11" Label="Source1" />
                        <Edge From="11" To="12" Label="Source1" />
                        <Edge From="12" To="13" Label="Source1" />
                        <Edge From="13" To="14" Label="Source1" />
                        <Edge From="14" To="15" Label="Source1" />
                        <Edge From="15" To="17" Label="Source1" />
                        <Edge From="16" To="17" Label="Source2" />
                        <Edge From="17" To="19" Label="Source1" />
                        <Edge From="18" To="19" Label="Source2" />
                      </Edges>
                    </Workflow>
                  </Expression>
                  <Expression xsi:type="IncludeWorkflow" Path="UclOpen.Devices:BehaviorBoard.BehaviorBoard.bonsai">
                    <CommandsSubjectName>BehaviorCommands</CommandsSubjectName>
                    <PortName>COM11</PortName>
                    <DumpRegisters>true</DumpRegisters>
                    <Heartbeat>Enabled</Heartbeat>
                    <EventsSubjectName>BehaviorEvents</EventsSubjectName>
                  </Expression>
                  <Expression xsi:type="IncludeWorkflow" Path="UclOpen.Devices:BehaviorBoard.CameraTriggerController.bonsai">
                    <TriggerFrequency>50</TriggerFrequency>
                    <BehaviorCommandsSubjectName>BehaviorCommands</BehaviorCommandsSubjectName>
                    <BehaviorEventsSubjectName>BehaviorEvents</BehaviorEventsSubjectName>
                    <CameraTriggerEventsSubjectName>CameraTriggerEvents</CameraTriggerEventsSubjectName>
                  </Expression>
                  <Expression xsi:type="IncludeWorkflow" Path="UclOpen.Devices:BehaviorBoard.PulseController.bonsai">
                    <BehaviorCommandsSubjectName>BehaviorCommands</BehaviorCommandsSubjectName>
                    <OutputPulseEnable>DO1 DO2 DO3</OutputPulseEnable>
                    <PulseDO1>100</PulseDO1>
                    <PulseDO2>100</PulseDO2>
                    <PulseDO3>100</PulseDO3>
                    <BehaviorEventsSubjectName>BehaviorEvents</BehaviorEventsSubjectName>
                    <TriggerPulseSubjectName>TriggerValve</TriggerPulseSubjectName>
                  </Expression>
                </Nodes>
                <Edges />
              </Workflow>
            </Expression>
            <Expression xsi:type="GroupWorkflow">
              <Name>StepperDriver</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>InitializeStepperDrivers</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="rx:BehaviorSubject" TypeArguments="harp:HarpMessage">
                          <rx:Name>StepperDriver1Commands</rx:Name>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="PortName" DisplayName="StepperDriver1PortName" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="p2:Device">
                            <harp:OperationMode>Active</harp:OperationMode>
                            <harp:OperationLed>On</harp:OperationLed>
                            <harp:DumpRegisters>true</harp:DumpRegisters>
                            <harp:VisualIndicators>On</harp:VisualIndicators>
                            <harp:Heartbeat>Enabled</harp:Heartbeat>
                            <harp:IgnoreErrors>false</harp:IgnoreErrors>
                            <harp:PortName>COM14</harp:PortName>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>StepperDriver1Events</Name>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject" TypeArguments="harp:HarpMessage">
                          <rx:Name>StepperDriver2Commands</rx:Name>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="PortName" DisplayName="StepperDriver2PortName" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="p2:Device">
                            <harp:OperationMode>Active</harp:OperationMode>
                            <harp:OperationLed>On</harp:OperationLed>
                            <harp:DumpRegisters>true</harp:DumpRegisters>
                            <harp:VisualIndicators>On</harp:VisualIndicators>
                            <harp:Heartbeat>Enabled</harp:Heartbeat>
                            <harp:IgnoreErrors>false</harp:IgnoreErrors>
                            <harp:PortName>COM12</harp:PortName>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>StepperDriver2Events</Name>
                        </Expression>
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="2" Label="Source1" />
                        <Edge From="1" To="2" Label="Source2" />
                        <Edge From="2" To="3" Label="Source1" />
                        <Edge From="4" To="6" Label="Source1" />
                        <Edge From="5" To="6" Label="Source2" />
                        <Edge From="6" To="7" Label="Source1" />
                      </Edges>
                    </Workflow>
                  </Expression>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>ReadSwitchStates</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>StepperDriver1Events</Name>
                        </Expression>
                        <Expression xsi:type="p2:Parse">
                          <harp:Register xsi:type="p2:DigitalInputState" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="p3:UnpackSwitchTriggers" />
                        </Expression>
                        <Expression xsi:type="Index">
                          <Operand xsi:type="IntProperty">
                            <Value>0</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>_Motor0_switchState</Name>
                        </Expression>
                        <Expression xsi:type="Index">
                          <Operand xsi:type="IntProperty">
                            <Value>1</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>_Motor1_switchState</Name>
                        </Expression>
                        <Expression xsi:type="Index">
                          <Operand xsi:type="IntProperty">
                            <Value>2</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>_Motor2_switchState</Name>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>StepperDriver2Events</Name>
                        </Expression>
                        <Expression xsi:type="p2:Parse">
                          <harp:Register xsi:type="p2:DigitalInputState" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="p3:UnpackSwitchTriggers" />
                        </Expression>
                        <Expression xsi:type="Index">
                          <Operand xsi:type="IntProperty">
                            <Value>0</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>_Motor3_switchState</Name>
                        </Expression>
                        <Expression xsi:type="Index">
                          <Operand xsi:type="IntProperty">
                            <Value>1</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="rx:BehaviorSubject">
                          <Name>_Motor4_switchState</Name>
                        </Expression>
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="1" Label="Source1" />
                        <Edge From="1" To="2" Label="Source1" />
                        <Edge From="2" To="3" Label="Source1" />
                        <Edge From="2" To="5" Label="Source1" />
                        <Edge From="2" To="7" Label="Source1" />
                        <Edge From="3" To="4" Label="Source1" />
                        <Edge From="5" To="6" Label="Source1" />
                        <Edge From="7" To="8" Label="Source1" />
                        <Edge From="9" To="10" Label="Source1" />
                        <Edge From="10" To="11" Label="Source1" />
                        <Edge From="11" To="12" Label="Source1" />
                        <Edge From="11" To="14" Label="Source1" />
                        <Edge From="12" To="13" Label="Source1" />
                        <Edge From="14" To="15" Label="Source1" />
                      </Edges>
                    </Workflow>
                  </Expression>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>InitialiseStepperDriverSettings</Name>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>StepperDriver1Events</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>20</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:TakeLast">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Delay">
                            <rx:DueTime>PT0.1S</rx:DueTime>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Unit" />
                        <Expression xsi:type="rx:Defer">
                          <Name>Initialize StepperDriver1</Name>
                          <Workflow>
                            <Nodes>
                              <Expression xsi:type="WorkflowInput">
                                <Name>Source1</Name>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateInterlockEnabledPayload">
                                  <p2:InterlockEnabled>Open</p2:InterlockEnabled>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateEnableDriverPayload">
                                  <p2:EnableDriver>Motor0 Motor1 Motor2</p2:EnableDriver>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor0MaximumRunCurrentPayload">
                                  <p2:Motor0MaximumRunCurrent>0.5</p2:Motor0MaximumRunCurrent>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor1MaximumRunCurrentPayload">
                                  <p2:Motor1MaximumRunCurrent>0.5</p2:Motor1MaximumRunCurrent>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor2MaximumRunCurrentPayload">
                                  <p2:Motor2MaximumRunCurrent>0.5</p2:Motor2MaximumRunCurrent>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor0MicrostepResolutionPayload">
                                  <p2:Motor0MicrostepResolution>Microstep8</p2:Motor0MicrostepResolution>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor1MicrostepResolutionPayload">
                                  <p2:Motor1MicrostepResolution>Microstep8</p2:Motor1MicrostepResolution>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateMotor2MicrostepResolutionPayload">
                                  <p2:Motor2MicrostepResolution>Microstep8</p2:Motor2MicrostepResolution>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateEnableEncodersPayload">
                                  <p2:EnableEncoders>Encoder0 Encoder1 Encoder2</p2:EnableEncoders>
                                </harp:Payload>
                              </Expression>
                              <Expression xsi:type="p2:CreateMessage">
                                <harp:MessageType>Write</harp:MessageType>
                                <harp:Payload xsi:type="p2:CreateResetEncodersPayload">
                                  <p2:ResetEncoders>Encoder0 Encoder1 Encoder2</p2:ResetEncoders>
