        <Combinator xsi:type="rx:Zip" />
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:SubscribeWhen" />
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>WheelDistanceCm</Name>
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>TrialStartWheelDistance</Name>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:WithLatestFrom" />
      </Expression>
      <Expression xsi:type="scr:ExpressionTransform">
        <scr:Name>TrialDistance</scr:Name>
        <scr:Expression>it.Item1 - it.Item2</scr:Expression>
      </Expression>
      <Expression xsi:type="rx:PublishSubject">
        <Name>TrialDistance</Name>
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>TrialDistance</Name>
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>TrialDistFloor</Name>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:WithLatestFrom" />
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>TrackLength</Name>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:WithLatestFrom" />
      </Expression>
      <Expression xsi:type="SubscribeSubject">
        <Name>TrialEnded</Name>
      </Expression>
      <Expression xsi:type="Combinator">
        <Combinator xsi:type="rx:WithLatestFrom" />
      </Expression>
      <Expression xsi:type="scr:ExpressionTransform">
        <scr:Name>CalcVirtualPos</scr:Name>
        <scr:Description>Prevent pos &lt; 0cm or &gt;TrackLengthcm. Gate on TrialEnded to prevent stale feedback.</scr:Description>
        <scr:Expression>new (
Convert.ToBoolean(it.Item2) ? 0.0 : Math.Min(it.Item1.Item1.Item2, it.Item1.Item1.Item1) as Floor,
Convert.ToBoolean(it.Item2) ? 0.0 : Math.Min((it.Item1.Item1.Item1 - Math.Min(it.Item1.Item1.Item2, it.Item1.Item1.Item1)), it.Item1.Item2) as VirtualPos
)</scr:Expression>
      </Expression>
      <Expression xsi:type="MemberSelector">
        <Selector>Floor</Selector>
      </Expression>
      <Expression xsi:type="MulticastSubject">
        <Name>TrialDistFloor</Name>
      </Expression>
      <Expression xsi:type="MemberSelector">
        <Selector>VirtualPos</Selector>
      </Expression>
      <Expression xsi:type="rx:PublishSubject">
        <Name>MouseVirtualPosition</Name>
      </Expression>
