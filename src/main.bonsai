      <Expression xsi:type="GroupWorkflow">
        <Name>ComputeRewardZone</Name>
        <Description />
        <Workflow>
          <Nodes>
            <Expression xsi:type="SubscribeSubject">
              <Name>TaskParams</Name>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>ComputeThreshold</scr:Name>
              <scr:Expression>it.ShapingStage == 1 ? Convert.ToDouble(it.ThresholdFrequencies.Stage1.Floor) : it.ShapingStage == 2 ? Convert.ToDouble(it.ThresholdFrequencies.Stage2.Floor) : it.ShapingStage == 3 ? Convert.ToDouble(it.ThresholdFrequencies.Stage3.Floor) : it.ShapingStage == 4 ? Convert.ToDouble(it.ThresholdFrequencies.Stage4.Floor) :  it.ShapingStage == 5 ? Convert.ToDouble(it.ThresholdFrequencies.Stage5.Floor) : Convert.ToDouble(it.ThresholdFrequencies.Stage6.Floor)</scr:Expression>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>RewardFloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TaskParams</Name>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>ComputeThreshold</scr:Name>
              <scr:Expression>it.ShapingStage == 1 ? Convert.ToDouble(it.ThresholdFrequencies.Stage1.Ceiling) : it.ShapingStage == 2 ? Convert.ToDouble(it.ThresholdFrequencies.Stage2.Ceiling) : it.ShapingStage == 3 ? Convert.ToDouble(it.ThresholdFrequencies.Stage3.Ceiling) : it.ShapingStage == 4 ? Convert.ToDouble(it.ThresholdFrequencies.Stage4.Ceiling) :  it.ShapingStage == 5 ? Convert.ToDouble(it.ThresholdFrequencies.Stage5.Ceiling) : Convert.ToDouble(it.ThresholdFrequencies.Stage6.Ceiling)</scr:Expression>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>RewardCeilFreq</Name>
            </Expression>
          </Nodes>
          <Edges>
            <Edge From="0" To="1" Label="Source1" />
            <Edge From="1" To="2" Label="Source1" />
            <Edge From="3" To="4" Label="Source1" />
            <Edge From="4" To="5" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>LickCounter</Name>
        <Description>Increments lick count on each lick</Description>
        <Workflow>
          <Nodes>
            <Expression xsi:type="SubscribeSubject">
              <Name>LickStateLeft</Name>
            </Expression>
            <Expression xsi:type="rx:Condition">
              <Workflow>
                <Nodes>
                  <Expression xsi:type="WorkflowInput">
                    <Name>Source1</Name>
                  </Expression>
                  <Expression xsi:type="WorkflowOutput" />
                </Nodes>
                <Edges>
                  <Edge From="0" To="1" Label="Source1" />
                </Edges>
              </Workflow>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>LickCount</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="MemberSelector">
              <Selector>Item2</Selector>
            </Expression>
            <Expression xsi:type="Add">
              <Operand xsi:type="IntProperty">
                <Value>1</Value>
              </Operand>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>LickCount</Name>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
          </Nodes>
          <Edges>
            <Edge From="0" To="1" Label="Source1" />
            <Edge From="1" To="3" Label="Source1" />
            <Edge From="2" To="3" Label="Source2" />
            <Edge From="3" To="4" Label="Source1" />
            <Edge From="4" To="5" Label="Source1" />
            <Edge From="5" To="6" Label="Source1" />
            <Edge From="6" To="7" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>TaskState</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Timer">
                <rx:DueTime>PT0S</rx:DueTime>
                <rx:Period>PT0.25S</rx:Period>
              </Combinator>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>ShapingStage</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TrialNumber</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>InterTrialInterval</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>WheelDistanceCm</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TrialDistance</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>MouseVirtualPosition</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>CurrFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TrackLength</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>RewardFloorFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>RewardCeilFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>"Stage:" + it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2.ToString() +
" Trial:" + it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2.ToString() +
" ITI:" + it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2.TotalSeconds.ToString("F0") + "s" + " TotDist:" + Convert.ToInt32(it.Item1.Item1.Item1.Item1.Item1.Item1.Item2).ToString() + "cm" +
" TrialDist:" + Convert.ToInt32(it.Item1.Item1.Item1.Item1.Item1.Item2).ToString() + "cm" +
" Position:" + Convert.ToInt32(it.Item1.Item1.Item1.Item1.Item2).ToString() + "cm" +
" Freq:" + Convert.ToInt32(it.Item1.Item1.Item1.Item2).ToString() + "Hz" +
" Track:" + Convert.ToInt32(it.Item1.Item1.Item2).ToString() + "cm" +
" Zone:" + Convert.ToInt32(it.Item1.Item2).ToString() + "-" + Convert.ToInt32(it.Item2).ToString() + "Hz"</scr:Expression>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
          </Nodes>
