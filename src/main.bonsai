                  <Expression xsi:type="scr:ExpressionTransform">
                    <scr:Name>FreqFromMoving</scr:Name>
                    <scr:Expression>it</scr:Expression>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>BeepTimer</Name>
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>EndFreqV</Name>
                  </Expression>
