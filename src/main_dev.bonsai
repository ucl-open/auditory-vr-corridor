            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>StartFreq</Name>
            </Expression>
            <Expression xsi:type="PropertyMapping">
              <PropertyMappings>
                <Property Name="Value" />
              </PropertyMappings>
            </Expression>
            <Expression xsi:type="Subtract">
              <Operand xsi:type="DoubleProperty">
                <Value>2000</Value>
              </Operand>
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>FreqFromMoving</scr:Name>
              <scr:Expression>it</scr:Expression>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>BeepTimer</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>EndFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>DriftBeepsTillEnd</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Zip" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>Multiplier</scr:Name>
              <scr:Expression>Math.Pow(it.Item2 / it.Item1, 1.0 / it.Item3)</scr:Expression>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>Multiplier^n-steps</scr:Name>
              <scr:Expression>Math.Pow(it.Item2, it.Item1)</scr:Expression>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>StartFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>geometric drift</scr:Name>
              <scr:Expression>it.item2 * it.Item1</scr:Expression>
            </Expression>
            <Expression xsi:type="PropertyMapping">
              <PropertyMappings>
                <Property Name="Value" />
              </PropertyMappings>
            </Expression>
            <Expression xsi:type="Add">
              <Operand xsi:type="DoubleProperty">
                <Value>302674.69446119771</Value>
              </Operand>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
