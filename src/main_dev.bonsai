                      </Expression>
                      <Expression xsi:type="SubscribeSubject">
                        <Name>TrackLength</Name>
                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="SubscribeSubject">
                        <Name>CurrFreq</Name>
                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="SubscribeSubject">
                        <Name>WheelDistanceCm</Name>
                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="SubscribeSubject">
                        <Name>LickCount</Name>
                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="SubscribeSubject">
                        <Name>WasRewarded</Name>
                      </Expression>
                      <Expression xsi:type="Combinator">
                        <Combinator xsi:type="rx:WithLatestFrom" />
                      </Expression>
                      <Expression xsi:type="scr:ExpressionTransform">
                        <scr:Name>FormatTrialData</scr:Name>
                        <scr:Expression>new 
(
Convert.ToDouble(it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1) as BonsaiTime,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as Trial,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as ShapingStage,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as RewFreqFloor,
it.Item1.Item1.Item1.Item1.Item1.Item2 as RewFreqCeil,
it.Item1.Item1.Item1.Item1.Item2 as TrackLength,
it.Item1.Item1.Item1.Item2 as CurrFreq,
it.Item1.Item1.Item2 as PosCm,
it.Item1.Item2 as LickCount,
it.Item2 as WasRewarded
)</scr:Expression>
                      </Expression>
                      <Expression xsi:type="io:CsvWriter">
                        <io:FileName>Logs/IntervalLogs/IntervalLog.csv</io:FileName>
                        <io:Append>false</io:Append>
                        <io:Overwrite>true</io:Overwrite>
                        <io:Suffix>Timestamp</io:Suffix>
                        <io:IncludeHeader>true</io:IncludeHeader>
                      </Expression>
                      <Expression xsi:type="Disable">
                        <Builder xsi:type="IncludeWorkflow" Path="UclOpen.Logging:LogHarpDevice.bonsai">
