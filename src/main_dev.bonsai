      <Expression xsi:type="GroupWorkflow">
        <Name>IsTrialEnd</Name>
        <Description>Determines trial end based on shaping stage</Description>
        <Workflow>
          <Nodes>
            <Expression xsi:type="SubscribeSubject">
              <Name>ShapingStage</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>CurrFreq</Name>
