              <scr:Expression>Convert.ToInt32(Math.Round(Math.Log(Convert.ToDouble(it.Item1.Item1) / Convert.ToDouble(it.Item2)) / Math.Log(Convert.ToDouble(it.Item3)  / Convert.ToDouble(it.Item2)) * (Convert.ToDouble(it.Item4) - 1.0)))</scr:Expression>
