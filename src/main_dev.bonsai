<?xml version="1.0" encoding="utf-8"?>
<WorkflowBuilder Version="2.9.0"
                 xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xmlns:beh="clr-namespace:Harp.Behavior;assembly=Harp.Behavior"
                 xmlns:harp="clr-namespace:Bonsai.Harp;assembly=Bonsai.Harp"
                 xmlns:rx="clr-namespace:Bonsai.Reactive;assembly=Bonsai.Core"
                 xmlns:dsp="clr-namespace:Bonsai.Dsp;assembly=Bonsai.Dsp"
                 xmlns:scr="clr-namespace:Bonsai.Scripting.Expressions;assembly=Bonsai.Scripting.Expressions"
                 xmlns:sys="clr-namespace:System;assembly=mscorlib"
                 xmlns:wie="clr-namespace:Bonsai.Windows.Input;assembly=Bonsai.Windows.Input"
                 xmlns:p1="clr-namespace:UclOpen.Core;assembly=UclOpen.Core"
                 xmlns:io="clr-namespace:Bonsai.IO;assembly=Bonsai.System"
                 xmlns:p2="clr-namespace:UclOpenAuditoryVrCorridorDataSchema;assembly=Extensions"
                 xmlns:p3="clr-namespace:UclOpen.Logging;assembly=UclOpen.Logging"
                 xmlns:p4="clr-namespace:UclOpen.Loggingv2;assembly=Extensions"
                 xmlns:p5="clr-namespace:Bonsai.Mixer;assembly=Bonsai.Mixer"
                 xmlns:gl="clr-namespace:Bonsai.Shaders;assembly=Bonsai.Shaders"
                 xmlns:res="clr-namespace:Bonsai.Resources;assembly=Bonsai.System"
                 xmlns:num="clr-namespace:Bonsai.Numerics;assembly=Bonsai.Numerics"
                 xmlns:p6="clr-namespace:Bonsai.Numerics.Distributions;assembly=Bonsai.Numerics"
                 xmlns:al="clr-namespace:Bonsai.Audio;assembly=Bonsai.Audio"
                 xmlns="https://bonsai-rx.org/2018/workflow">
  <Workflow>
    <Nodes>
      <Expression xsi:type="GroupWorkflow">
        <Name>IncludedWorkflows</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Disable">
              <Builder xsi:type="IncludeWorkflow" Path="UclOpen.Devices:LicketySplit.bonsai">
                <CommandsSubjectName>LickCommands</CommandsSubjectName>
                <EventsSubjectName>LickEvents</EventsSubjectName>
                <LickStateSubjectName>LickState</LickStateSubjectName>
              </Builder>
            </Expression>
            <Expression xsi:type="IncludeWorkflow" Path="UclOpen.Devices:DeviceBehaviorBoard.BehaviorBoard.bonsai">
              <CommandsSubjectName>BehaviorCommands</CommandsSubjectName>
              <PortName>COM3</PortName>
              <DumpRegisters>true</DumpRegisters>
              <Heartbeat>Disabled</Heartbeat>
              <EventsSubjectName>BehaviorEvents</EventsSubjectName>
            </Expression>
            <Expression xsi:type="GroupWorkflow">
              <Name>RunningWheel</Name>
              <Workflow>
                <Nodes>
                  <Expression xsi:type="beh:CreateMessage">
                    <harp:MessageType>Write</harp:MessageType>
                    <harp:Payload xsi:type="beh:CreateEnableEncodersPayload">
                      <beh:EnableEncoders>EncoderPort2</beh:EnableEncoders>
                    </harp:Payload>
                  </Expression>
                  <Expression xsi:type="beh:CreateMessage">
                    <harp:MessageType>Write</harp:MessageType>
                    <harp:Payload xsi:type="beh:CreateEncoderModePayload">
                      <beh:EncoderMode>Displacement</beh:EncoderMode>
                    </harp:Payload>
                  </Expression>
                  <Expression xsi:type="beh:CreateMessage">
                    <harp:MessageType>Write</harp:MessageType>
                    <harp:Payload xsi:type="beh:CreateEncoderResetPayload">
                      <beh:EncoderReset>EncoderPort2</beh:EncoderReset>
                    </harp:Payload>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:Merge" />
                  </Expression>
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="Name" DisplayName="CommandsSubjectName" Description="The name of the Subject that carries command messages for a specific behavior device" Category="Subjects" />
                  </Expression>
                  <Expression xsi:type="MulticastSubject">
                    <Name>BehaviorCommands</Name>
                  </Expression>
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="Name" DisplayName="EventsSubjectName" Description="The name of the Subject that carries event messages from a specific behavior device" Category="Subjects" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>BehaviorEvents</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:SubscribeWhen" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>BehaviorEvents</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:DelaySubscription">
                      <rx:DueTime>PT0.5S</rx:DueTime>
                    </Combinator>
                  </Expression>
                  <Expression xsi:type="beh:Parse">
                    <harp:Register xsi:type="beh:AnalogData" />
                  </Expression>
                  <Expression xsi:type="MemberSelector">
                    <Selector>Encoder</Selector>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="dsp:Difference">
                      <dsp:Order>1</dsp:Order>
                    </Combinator>
                  </Expression>
                  <Expression xsi:type="Disable">
                    <Builder xsi:type="scr:ExpressionTransform">
                      <scr:Name>ConvertSigned</scr:Name>
                      <scr:Expression>it &gt; 32768.0 ? it - 65536.0 : (it &lt; -32768.0 ? it + 65536.0 : it)</scr:Expression>
                    </Builder>
                  </Expression>
                  <Expression xsi:type="rx:Accumulate" />
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="CountsPerRev" />
                    <Property Name="WheelDiameterMm" />
                  </Expression>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>TicksToCentimeters</Name>
                    <Description>Converts steps on a quadrature encoder to a distance in cm, published to a Subject</Description>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="WorkflowInput">
                          <Name>Source1</Name>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Value" DisplayName="CountsPerRev" Description="The number of steps recorded on the quadrature encoder in a full revolution" Category="Running Wheel" />
                        </Expression>
                        <Expression xsi:type="Divide">
                          <Operand xsi:type="WorkflowProperty" TypeArguments="sys:Int16">
                            <Value>4096</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Value" DisplayName="WheelDiameterMm" Description="The diameter of the wheel, in millimetres" Category="Running Wheel" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="IntProperty">
                            <Value>170</Value>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="scr:ExpressionTransform">
                          <scr:Name>CircumferenceCm</scr:Name>
                          <scr:Expression>(it*Math.Pi)/10</scr:Expression>
                        </Expression>
                        <Expression xsi:type="PropertyMapping">
                          <PropertyMappings>
                            <Property Name="Value" />
                          </PropertyMappings>
                        </Expression>
                        <Expression xsi:type="Multiply">
                          <Operand xsi:type="FloatProperty">
                            <Value>53.407074</Value>
                          </Operand>
                        </Expression>
                        <Expression xsi:type="WorkflowOutput" />
                      </Nodes>
                      <Edges>
                        <Edge From="0" To="2" Label="Source2" />
                        <Edge From="1" To="2" Label="Source3" />
                        <Edge From="2" To="7" Label="Source1" />
                        <Edge From="3" To="4" Label="Source1" />
                        <Edge From="4" To="5" Label="Source1" />
                        <Edge From="5" To="6" Label="Source1" />
                        <Edge From="6" To="7" Label="Source2" />
                        <Edge From="7" To="8" Label="Source1" />
                      </Edges>
                    </Workflow>
                  </Expression>
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="Name" DisplayName="WheelDistanceSubjectName" Description="The name of the Subject that carries the wheel distance in cm" Category="Subjects" />
                  </Expression>
                  <Expression xsi:type="rx:PublishSubject">
                    <Name>WheelDistanceCm</Name>
                  </Expression>
                </Nodes>
                <Edges>
                  <Edge From="0" To="3" Label="Source1" />
                  <Edge From="1" To="3" Label="Source2" />
                  <Edge From="2" To="3" Label="Source3" />
                  <Edge From="3" To="5" Label="Source1" />
                  <Edge From="4" To="5" Label="Source2" />
                  <Edge From="5" To="8" Label="Source1" />
                  <Edge From="6" To="7" Label="Source1" />
                  <Edge From="6" To="9" Label="Source1" />
                  <Edge From="7" To="8" Label="Source2" />
                  <Edge From="9" To="10" Label="Source1" />
                  <Edge From="10" To="11" Label="Source1" />
                  <Edge From="11" To="12" Label="Source1" />
                  <Edge From="12" To="13" Label="Source1" />
                  <Edge From="13" To="14" Label="Source1" />
                  <Edge From="14" To="15" Label="Source1" />
                  <Edge From="15" To="17" Label="Source1" />
                  <Edge From="16" To="17" Label="Source2" />
                  <Edge From="17" To="19" Label="Source1" />
                  <Edge From="18" To="19" Label="Source2" />
                </Edges>
              </Workflow>
            </Expression>
            <Expression xsi:type="IncludeWorkflow" Path="UclOpen.Devices:DeviceBehaviorBoard.Timestamps.bonsai">
              <EventsSubjectName>BehaviorEvents</EventsSubjectName>
              <CommandsSubjectName>BehaviorCommands</CommandsSubjectName>
            </Expression>
          </Nodes>
          <Edges />
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>TaskState</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:Timer">
                <rx:DueTime>PT0S</rx:DueTime>
                <rx:Period>PT0.25S</rx:Period>
              </Combinator>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>ShapingStage</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TrialNumber</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>InterTrialInterval</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>WheelDistanceCm</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>CurrFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>TrackLength</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>RewardFloorFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>RewardCeilFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Expression>"Stage:" + it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2.ToString() +
" Trial:" + it.Item1.Item1.Item1.Item1.Item1.Item1.Item2.ToString() +
" ITI:" + it.Item1.Item1.Item1.Item1.Item1.Item2.TotalSeconds.ToString("F0") + "s" +
" Dist:" + Convert.ToInt32(it.Item1.Item1.Item1.Item1.Item2).ToString() + "cm" +
" Freq:" + Convert.ToInt32(it.Item1.Item1.Item1.Item2).ToString() + "Hz" +
" Track:" + Convert.ToInt32(it.Item1.Item1.Item2).ToString() + "cm" +
" Zone:" + Convert.ToInt32(it.Item1.Item2).ToString() + "-" + Convert.ToInt32(it.Item2).ToString() + "Hz"</scr:Expression>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
          </Nodes>
          <Edges>
            <Edge From="0" To="2" Label="Source1" />
            <Edge From="1" To="2" Label="Source2" />
            <Edge From="2" To="4" Label="Source1" />
            <Edge From="3" To="4" Label="Source2" />
            <Edge From="4" To="6" Label="Source1" />
            <Edge From="5" To="6" Label="Source2" />
            <Edge From="6" To="8" Label="Source1" />
            <Edge From="7" To="8" Label="Source2" />
            <Edge From="8" To="10" Label="Source1" />
            <Edge From="9" To="10" Label="Source2" />
            <Edge From="10" To="12" Label="Source1" />
            <Edge From="11" To="12" Label="Source2" />
            <Edge From="12" To="14" Label="Source1" />
            <Edge From="13" To="14" Label="Source2" />
            <Edge From="14" To="16" Label="Source1" />
            <Edge From="15" To="16" Label="Source2" />
            <Edge From="16" To="17" Label="Source1" />
            <Edge From="17" To="18" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>ComputeRewardZone</Name>
        <Description />
        <Workflow>
          <Nodes>
            <Expression xsi:type="SubscribeSubject">
              <Name>ShapingStage</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage1FloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage2FloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage3FloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage4FloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage5FloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage6FloorFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:CombineLatest" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>ComputeThreshold</scr:Name>
              <scr:Expression>it.Item1 == 1 ? Convert.ToDouble(it.Item2) : it.Item1 == 2 ? Convert.ToDouble(it.Item3) : it.Item1 == 3 ? Convert.ToDouble(it.Item4) : it.Item1 == 4 ? Convert.ToDouble(it.Item5) :  it.Item1 == 5 ? Convert.ToDouble(it.Item6) : Convert.ToDouble(it.Item7)</scr:Expression>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>RewardFloorFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>ShapingStage</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage1CeilFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage2CeilFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage3CeilFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage4CeilFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage5CeilFreq</Name>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>Stage6CeilFreq</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:CombineLatest" />
            </Expression>
            <Expression xsi:type="scr:ExpressionTransform">
              <scr:Name>ComputeThreshold</scr:Name>
              <scr:Expression>it.Item1 == 1 ? Convert.ToDouble(it.Item2) : it.Item1 == 2 ? Convert.ToDouble(it.Item3) : it.Item1 == 3 ? Convert.ToDouble(it.Item4) : it.Item1 == 4 ? Convert.ToDouble(it.Item5) :  it.Item1 == 5 ? Convert.ToDouble(it.Item6) : Convert.ToDouble(it.Item7)</scr:Expression>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>RewardCeilFreq</Name>
            </Expression>
          </Nodes>
          <Edges>
            <Edge From="0" To="7" Label="Source1" />
            <Edge From="1" To="7" Label="Source2" />
            <Edge From="2" To="7" Label="Source3" />
            <Edge From="3" To="7" Label="Source4" />
            <Edge From="4" To="7" Label="Source5" />
            <Edge From="5" To="7" Label="Source6" />
            <Edge From="6" To="7" Label="Source7" />
            <Edge From="7" To="8" Label="Source1" />
            <Edge From="8" To="9" Label="Source1" />
            <Edge From="10" To="17" Label="Source1" />
            <Edge From="11" To="17" Label="Source2" />
            <Edge From="12" To="17" Label="Source3" />
            <Edge From="13" To="17" Label="Source4" />
            <Edge From="14" To="17" Label="Source5" />
            <Edge From="15" To="17" Label="Source6" />
            <Edge From="16" To="17" Label="Source7" />
            <Edge From="17" To="18" Label="Source1" />
            <Edge From="18" To="19" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>LickCounter</Name>
        <Description>Increments lick count on each lick</Description>
        <Workflow>
          <Nodes>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="wie:KeyDown">
                <wie:Filter>L</wie:Filter>
                <wie:SuppressRepetitions>false</wie:SuppressRepetitions>
              </Combinator>
            </Expression>
            <Expression xsi:type="SubscribeSubject">
              <Name>LickCount</Name>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="rx:WithLatestFrom" />
            </Expression>
            <Expression xsi:type="MemberSelector">
              <Selector>Item2</Selector>
            </Expression>
            <Expression xsi:type="Add">
              <Operand xsi:type="IntProperty">
                <Value>1</Value>
              </Operand>
            </Expression>
            <Expression xsi:type="MulticastSubject">
              <Name>LickCount</Name>
            </Expression>
            <Expression xsi:type="WorkflowOutput" />
          </Nodes>
          <Edges>
            <Edge From="0" To="2" Label="Source1" />
            <Edge From="1" To="2" Label="Source2" />
            <Edge From="2" To="3" Label="Source1" />
            <Edge From="3" To="4" Label="Source1" />
            <Edge From="4" To="5" Label="Source1" />
            <Edge From="5" To="6" Label="Source1" />
          </Edges>
        </Workflow>
      </Expression>
      <Expression xsi:type="GroupWorkflow">
        <Name>Logging</Name>
        <Workflow>
          <Nodes>
            <Expression xsi:type="GroupWorkflow">
              <Name>TrialLogger</Name>
              <Description />
              <Workflow>
                <Nodes>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>TrialEnded</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:Timestamp" />
                  </Expression>
                  <Expression xsi:type="MemberSelector">
                    <Selector>Timestamp.TimeOfDay.TotalMilliseconds</Selector>
                  </Expression>
                  <Expression xsi:type="Format">
                    <Format>{0:F2}</Format>
                    <Selector />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>TrialNumber</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>ShapingStage</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>RewardFloorFreq</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>RewardCeilFreq</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>TrialEndFreq</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>TrackLength</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>WheelDistanceCm</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>LickCount</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="SubscribeSubject">
                    <Name>WasRewarded</Name>
                  </Expression>
                  <Expression xsi:type="Combinator">
                    <Combinator xsi:type="rx:WithLatestFrom" />
                  </Expression>
                  <Expression xsi:type="scr:ExpressionTransform">
                    <scr:Name>FormatTrialData</scr:Name>
                    <scr:Expression>new 
(
it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1 as BonsaiTime,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as Trial,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as ShapingStage,
it.Item1.Item1.Item1.Item1.Item1.Item1.Item2 as RewFreqFloor,
it.Item1.Item1.Item1.Item1.Item1.Item2 as RewFreqCeil,
it.Item1.Item1.Item1.Item1.Item2 as TrialEndFreq,
it.Item1.Item1.Item1.Item2 as TrackLength,
it.Item1.Item1.Item2 as TrialEndPosCm,
it.Item1.Item2 as LickCount,
it.Item2 as WasRewarded
)</scr:Expression>
                  </Expression>
                  <Expression xsi:type="ExternalizedMapping">
                    <Property Name="Name" />
                    <Property Name="Extension" />
                  </Expression>
                  <Expression xsi:type="GroupWorkflow">
                    <Name>FormatFileName</Name>
                    <Description>Generates a log filename based on the input timestamp.</Description>
                    <Workflow>
                      <Nodes>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>PathPrefix</Name>
                        </Expression>
                        <Expression xsi:type="WorkflowInput">
                          <Name>Source1</Name>
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Value" DisplayName="Name" Description="The base name of the log file." />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="StringProperty">
                            <Value>TrialLog</Value>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="SubscribeSubject">
                          <Name>AnimalAndSessionID</Name>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Zip" />
                        </Expression>
                        <Expression xsi:type="Format">
                          <Format>{0}_{1}_</Format>
                          <Selector>Item1, Item2</Selector>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="p1:StripSubstring" />
                        </Expression>
                        <Expression xsi:type="ExternalizedMapping">
                          <Property Name="Value" DisplayName="Extension" Description="The file extension" />
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="StringProperty">
                            <Value>csv</Value>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Take">
                            <rx:Count>1</rx:Count>
                          </Combinator>
                        </Expression>
                        <Expression xsi:type="Combinator">
                          <Combinator xsi:type="rx:Zip" />
                        </Expression>
                        <Expression xsi:type="Format">
